<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp">

    <!-- 상단: 제목 -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="참괜찮은 사무실"
        android:textColor="#F2F2F5"
        android:textSize="14sp"
        android:textStyle="bold" />

    <!-- 사건 현황 3칸 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        android:weightSum="3">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_chip"
            android:padding="6dp">
            <TextView
                android:id="@+id/widget_inprogress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#E8E8EA"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="진행중"
                android:textColor="#9A9AA0"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_chip"
            android:padding="6dp">
            <TextView
                android:id="@+id/widget_need"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF9F0A"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="확인필요"
                android:textColor="#9A9AA0"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/widget_chip"
            android:padding="6dp">
            <TextView
                android:id="@+id/widget_deadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FF453A"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="임박마감"
                android:textColor="#9A9AA0"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- 해야 할 일 -->
    <TextView
        android:id="@+id/widget_todo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="해야 할 일"
        android:textColor="#E8E8EA"
        android:textSize="12sp"
        android:layout_marginTop="10dp" />

    <!-- 안 읽은 쪽지 -->
    <TextView
        android:id="@+id/widget_msg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="안 읽은 쪽지"
        android:textColor="#E8E8EA"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

</LinearLayout>
